{
  "name": "ds",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "build:web": "pnpm -r run build && node tools/assemble-site.mjs",
    "dev": "pnpm run --filter @dku/tokens --filter storybook dev --parallel",
    "dev:web": "pnpm run --filter @dku/tokens --filter promo --filter storybook dev --parallel",
    "test": "vitest run",
    "lint": "eslint . && stylelint 'packages/react/src/**/*.module.css'",
    "lint:css": "stylelint 'packages/react/src/**/*.module.css'"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "stylelint": "^17.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
